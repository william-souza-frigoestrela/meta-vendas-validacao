	measure 'Peso Mix' =
			
			VAR MetaAtual      = SELECTEDVALUE(FPBI_ESTRELA_METAS[META])
			VAR DtaFimPeriodo  = SELECTEDVALUE(FPBI_ESTRELA_METAS[DTAVALIDADE])
			
			-- Calcula início da quinzena a partir da DTAVALIDADE da meta
			VAR DtaInicioPeriodo =
			    IF(
			        DAY(DtaFimPeriodo) <= 15,
			        DATE(YEAR(DtaFimPeriodo), MONTH(DtaFimPeriodo), 1),   -- 1ª quinzena: dia 1
			        DATE(YEAR(DtaFimPeriodo), MONTH(DtaFimPeriodo), 16)   -- 2ª quinzena: dia 16
			    )
			
			-- Produtos válidos para esta meta + vendedor + quinzena exata
			-- (filtro de vendedor já propagado via relacionamento mixDiversos → DCV_VENDEDORHIERARQUIANIVEL)
			VAR ProdutosMix =
			    SELECTCOLUMNS(
			        FILTER(
			            mixDiversos,
			            mixDiversos[META]        = MetaAtual      &&   -- MIX BOVINO / SUINO / etc
			            mixDiversos[DTAVALIDADE] = DtaFimPeriodo        -- quinzena exata
			        ),
			        "PROD", mixDiversos[SEQPRODUTO]
			    )
			
			RETURN
			IF(
			    NOT ISBLANK(DtaFimPeriodo) && NOT ISBLANK(MetaAtual),
			    CALCULATE(
			        SUMX(
			            DCVV_META_VENDADEVOLUCAOMIX,
			            DCVV_META_VENDADEVOLUCAOMIX[PESOVENDA] -
			            DCVV_META_VENDADEVOLUCAOMIX[PESODEVOLUCAO]
			        ),
			        -- Filtra pelo período exato da quinzena
			        DCVV_META_VENDADEVOLUCAOMIX[DTAEMISSAO] >= DtaInicioPeriodo,
			        DCVV_META_VENDADEVOLUCAOMIX[DTAEMISSAO] <= DtaFimPeriodo,
			        -- Filtra pelos produtos do mix desta quinzena
			        TREATAS(ProdutosMix, DCVV_META_VENDADEVOLUCAOMIX[SEQPRODUTO])
			    )
			)
		displayFolder: Resultado realizado
		lineageTag: cacbc86f-9b33-4c6c-b1ee-3ddb28677956

		annotation PBI_FormatHint = {"isGeneralNumber":true}

