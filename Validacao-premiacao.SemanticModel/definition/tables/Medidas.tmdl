		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Positivação =
			
			VAR ClientesSaldo =
			    ADDCOLUMNS(
			        SUMMARIZE(
			            DCVV_META_VENDADEVOLUCAO,
			            DCVV_META_VENDADEVOLUCAO[SEQCLIENTE]
			        ),
			        "NetPeso",
			        CALCULATE(
			            SUM(DCVV_META_VENDADEVOLUCAO[PESOVENDA]) -
			            SUM(DCVV_META_VENDADEVOLUCAO[PESODEVOLUCAO])
			        )
			    )
			RETURN
			COUNTROWS(FILTER(ClientesSaldo, [NetPeso] > 0))
		formatString: 0
		displayFolder: Resultado realizado
		lineageTag: a423648d-c244-4382-b738-a85a8dc6e2d6

	measure 'Recorrencia positivacao' = ```
			
			CALCULATE(
			
			    DISTINCTCOUNT(DCVV_META_RVV_FERIAS[SEQCLIENTE]),
			    DCVV_META_RVV_FERIAS[CONTAGEM] > 0,
			    REMOVEFILTERS(DimMes)
			    
			)
			```
		formatString: 0
		displayFolder: Resultado realizado
		lineageTag: d888adb6-3588-489f-8a81-572f187d3322

	measure '% Realizado recorrecnia positivacao' =
			
