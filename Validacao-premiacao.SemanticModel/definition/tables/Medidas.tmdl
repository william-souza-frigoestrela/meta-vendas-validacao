	measure 'Itens totais' = ```
			
			VAR ProdutosValidos =
			    FILTER(
			        ADDCOLUMNS(
			            SUMMARIZE(
			                DCVV_META_VENDADEVOLUCAO,
			                DCVV_META_VENDADEVOLUCAO[SEQCLIENTE],
			                DCVV_META_VENDADEVOLUCAO[SEQPRODUTO]
			            ),
			            "NetPeso",
			            CALCULATE(
			                SUM(DCVV_META_VENDADEVOLUCAO[PESOVENDA]) -
			                SUM(DCVV_META_VENDADEVOLUCAO[PESODEVOLUCAO])
			            )
			        ),
			        [NetPeso] > 0   -- << troca por VLRVENDA - VLRDEVOLUCAO se for valor
			    )
			RETURN
			COUNTROWS(ProdutosValidos)
			
			```
		formatString: 0
		displayFolder: Resultado realizado
		lineageTag: 8300ea62-8d60-482f-a5fe-d0dd87023f0b

