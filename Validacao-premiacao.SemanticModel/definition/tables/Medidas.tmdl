	measure Bonificação = ```
			
			var seqnivel = SELECTEDVALUE(DCV_VENDEDORHIERARQUIANIVEL[SEQNIVEL])
			var varejo_sul = seqnivel in {"31","37"}
			
			var base_percent_devolucao =  
			    IF(varejo_sul,[Salario vendedor]*0.01,[Salario vendedor]*0.04)
			
			var base_percent_peso_total=
			    IF(varejo_sul,[Salario vendedor]*0.04,[Salario vendedor]*0.03)
			
			var base_percent_faturmanto_total = 
			    IF(varejo_sul,[Salario vendedor]*0.04,[Salario vendedor]*0.03)
			
			var base_percent_peso_suino = 
			    IF(varejo_sul,[Salario vendedor]*0.08,[Salario vendedor]*0.05)
			
			var base_percent_peso_industrializados = 
			    IF(varejo_sul,[Salario vendedor]*0.15,[Salario vendedor]*0.1)
			
			var base_percent_faturamento_suino = 
			    IF(varejo_sul,[Salario vendedor]*0.06,[Salario vendedor]*0.05)
			
			var base_percent_mix_suino = 
			    if(varejo_sul,[Salario vendedor]*0.025,[Salario vendedor]*0.02)
			
			var base_percent_recorrecnia_positivacao = 
			    if(varejo_sul,[Salario vendedor]*0.1,[Salario vendedor]*0.05)
			
			RETURN
			
			SWITCH(
			    SELECTEDVALUE(FPBI_ESTRELA_METAS[Meta]),
			
			        "Peso bovino",
			            SWITCH(
			                TRUE(),
			                [% Realizado peso bovino] <0.70 ,0,
			                [% Realizado peso bovino] >=0.70 && [% Realizado peso bovino] < 0.80, ([Salario vendedor]*0.05)*0.2,
			                [% Realizado peso bovino] >=0.80 && [% Realizado peso bovino] < 0.90, ([Salario vendedor]*0.05)*0.4,
			                [% Realizado peso bovino] >=0.90 && [% Realizado peso bovino] < 1, ([Salario vendedor]*0.05)*0.75,
			                [% Realizado peso bovino] >=1 && [% Realizado peso bovino] < 1.05, ([Salario vendedor]*0.05)*1,
			                [% Realizado peso bovino] >=1 && [% Realizado peso bovino] < 1.05, ([Salario vendedor]*0.05)*1,
			                [% Realizado peso bovino] >=1.05 && [% Realizado peso bovino] < 1.10, ([Salario vendedor]*0.05)*1.10,
			                [% Realizado peso bovino] >=1.10 && [% Realizado peso bovino] < 1.15, ([Salario vendedor]*0.05)*1.15,
			                ([Salario vendedor]*0.05)*1.20
			            ),
			
			        "Peso suinos",
			            SWITCH(
			                TRUE(),
			                [% Realizado peso suino] <0.70 ,0,
			                [% Realizado peso suino] >=0.70 && [% Realizado peso suino] < 0.80, (base_percent_peso_suino)*0.2,
			                [% Realizado peso suino] >=0.80 && [% Realizado peso suino] < 0.90, (base_percent_peso_suino)*0.4,
			                [% Realizado peso suino] >=0.90 && [% Realizado peso suino] < 1, (base_percent_peso_suino)*0.75,
			                [% Realizado peso suino] >=1 && [% Realizado peso suino] < 1.05, (base_percent_peso_suino)*1,
			                [% Realizado peso suino] >=1.05 && [% Realizado peso suino] < 1.10, (base_percent_peso_suino*0.05)*1.10,
			                [% Realizado peso suino] >=1.10 && [% Realizado peso suino] < 1.15, (base_percent_peso_suino*0.05)*1.15,
			                (base_percent_peso_suino)*1.20
			            ),
			
			        "Peso industrializados",
			            SWITCH(
			                TRUE(),
			                [% Realizado peso industrializados] <0.70 ,0,
			                [% Realizado peso industrializados] >=0.70 && [% Realizado peso industrializados] < 0.80, (base_percent_peso_industrializados)*0.2,
			                [% Realizado peso industrializados] >=0.80 && [% Realizado peso industrializados] < 0.90, (base_percent_peso_industrializados)*0.4,
			                [% Realizado peso industrializados] >=0.90 && [% Realizado peso industrializados] < 1, (base_percent_peso_industrializados)*0.75,
			                [% Realizado peso industrializados] >=1 && [% Realizado peso industrializados] < 1.05, (base_percent_peso_industrializados)*1,
			                [% Realizado peso industrializados] >=1.05 && [% Realizado peso industrializados] < 1.10, (base_percent_peso_industrializados)*1.10,
			                [% Realizado peso industrializados] >=1.10 && [% Realizado peso industrializados] < 1.15, (base_percent_peso_industrializados)*1.15,
			                (base_percent_peso_industrializados)*1.20
			            ),
			
			        "Peso total",
			            SWITCH(
			                TRUE(),
			                [% Realizado peso total] <0.70 ,0,
			                [% Realizado peso total] >=0.70 && [% Realizado peso total] < 0.80, (base_percent_peso_total)*0.2,
			                [% Realizado peso total] >=0.80 && [% Realizado peso total] < 0.90, (base_percent_peso_total)*0.4,
			                [% Realizado peso total] >=0.90 && [% Realizado peso total] < 1, (base_percent_peso_total)*0.75,
			                [% Realizado peso total] >=1 && [% Realizado peso total] < 1.05, (base_percent_peso_total)*1,
			                [% Realizado peso total] >=1.05 && [% Realizado peso total] < 1.10, (base_percent_peso_total)*1.10,
			                [% Realizado peso total] >=1.10 && [% Realizado peso total] < 1.15, (base_percent_peso_total)*1.15,
			                (base_percent_peso_total)*1.20
			            ),
			
			        "Faturamento Suinos",
			            SWITCH(
			                TRUE(),
			                [% Realizado faturamento suinos] <0.70 ,0,
			                [% Realizado faturamento suinos] >=0.70 && [% Realizado faturamento suinos] < 0.80, (base_percent_faturamento_suino)*0.2,
			                [% Realizado faturamento suinos] >=0.80 && [% Realizado faturamento suinos] < 0.90, (base_percent_faturamento_suino)*0.4,
			                [% Realizado faturamento suinos] >=0.90 && [% Realizado faturamento suinos] < 1, (base_percent_faturamento_suino)*0.75,
			                [% Realizado faturamento suinos] >=1 && [% Realizado faturamento suinos] < 1.05, (base_percent_faturamento_suino)*1,
			                [% Realizado faturamento suinos] >=1.05 && [% Realizado faturamento suinos] < 1.10, (base_percent_faturamento_suino)*1.10,
			                [% Realizado faturamento suinos] >=1.10 && [% Realizado faturamento suinos] < 1.15, (base_percent_faturamento_suino)*1.15,
			                (base_percent_faturamento_suino)*1.20
			            ),
			
			        "Faturamento bovinos",
			            SWITCH(
			                TRUE(),
