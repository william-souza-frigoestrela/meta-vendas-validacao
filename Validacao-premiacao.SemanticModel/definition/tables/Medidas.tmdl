		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Peso Mix Rentável' =
			
			VAR AnoMesAtual = SELECTEDVALUE(DimMes[AnoMes])
			
			-- Remove filtro de data (cadeia problemática) mas mantém filtro de vendedor
			VAR ProdutosMix =
			    SELECTCOLUMNS(
			        CALCULATETABLE(
			            produtosMIXRENTAVEL,
			            REMOVEFILTERS(dCalendario),                  -- remove dependência da cadeia de data
			            produtosMIXRENTAVEL[ANOMES] = AnoMesAtual   -- filtra mês diretamente
			        ),
			        "PROD", produtosMIXRENTAVEL[SEQPRODUTO]
			    )
			
			RETURN
			IF(
			    NOT ISEMPTY(ProdutosMix),
			    CALCULATE(
			        SUM(DCVV_META_VENDADEVOLUCAOMIXRENTAVEL[PESOVENDA]) -
			        SUM(DCVV_META_VENDADEVOLUCAOMIXRENTAVEL[PESODEVOLUCAO]),
			        TREATAS(ProdutosMix, DCVV_META_VENDADEVOLUCAOMIXRENTAVEL[SEQPRODUTO])
			    )
			)
		displayFolder: Resultado realizado
		lineageTag: 51e0faf2-4997-4c34-9dbc-459d9f588e18

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Realizado mix rentavel' =
			
			DIVIDE([Peso Mix Rentável],[Meta valor],0)
		displayFolder: % Realizado
		lineageTag: 4370c896-729a-4fe5-9020-fd7e2b97d766

		annotation PBI_FormatHint = {"isGeneralNumber":true}

