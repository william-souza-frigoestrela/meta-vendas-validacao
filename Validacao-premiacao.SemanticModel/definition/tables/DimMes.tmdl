	partition DimMes = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    SUMMARIZE(
				        DCalendario,
				        DCalendario[Ano2],
				        DCalendario[Mês num]
				    ),
				    "AnoMes", FORMAT(DATE(DCalendario[Ano2], DCalendario[Mês num], 1), "YYYYMM"),
				    "InicioMes", CALCULATE(MIN(DCalendario[Date])),
				    "FimMes", CALCULATE(MAX(DCalendario[Date]))
				)

	annotation PBI_Id = 4a4eeb60c64d4b47a280ed673f7295d1

