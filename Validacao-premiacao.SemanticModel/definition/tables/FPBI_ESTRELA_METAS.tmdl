	column DTAVALIDADE
		dataType: dateTime
		formatString: General Date
		lineageTag: 1c71115d-7817-4008-8bee-4865ce40d1b7
		summarizeBy: none
		sourceColumn: DTAVALIDADE

		annotation SummarizationSetBy = Automatic

	column 'Meta Display' =
			
			VAR NomeMeta = FPBI_ESTRELA_METAS[META]
			VAR Dia = DAY(FPBI_ESTRELA_METAS[DTAVALIDADE])
			
			RETURN
			IF(
			    NomeMeta IN {
			        "MIX BOVINO",
			        "MIX SUINO",
			        "MIX INDUSTRIALIZADOS"
			    },
			    NomeMeta & " - " &
			        IF(Dia <= 15, "1ª Quinzena", "2ª Quinzena"),
			    NomeMeta
			)
		lineageTag: b889dc60-5978-46b1-bdf2-a9faf5f8dfcb
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column VLRMETA
