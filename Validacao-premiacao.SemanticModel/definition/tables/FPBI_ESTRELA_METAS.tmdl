		summarizeBy: sum
		sourceColumn: VLRMETA

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition FPBI_ESTRELA_METAS = m
		mode: import
		source =
				let
				    Fonte = Oracle.Database("datavale", [HierarchicalNavigation=true]),
				    DATAVALE = Fonte{[Schema="DATAVALE"]}[Data],
				    FPBI_ESTRELA_METAS1 = DATAVALE{[Name="FPBI_ESTRELA_METAS"]}[Data],
				    #"Tipo Alterado" = Table.TransformColumnTypes(FPBI_ESTRELA_METAS1,{{"SEQVENDEDOR", type text}}),
				
				    #"Coluna Ajustada" =
				        Table.AddColumn(
				            #"Tipo Alterado",
				            "VLRMETA_Ajustado",
				            each if [SEQMETA] = 17 then [VLRMETA] * 0.1 else [VLRMETA],
				            type number
				        ),
				
				    #"Remove Antiga" =
				        Table.RemoveColumns(#"Coluna Ajustada", {"VLRMETA"}),
				
				    #"Renomeia Nova" =
				        Table.RenameColumns(#"Remove Antiga", {{"VLRMETA_Ajustado", "VLRMETA"}})
				in
				    #"Renomeia Nova"

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Table

